{
  "annotations": {"list": []},
  "editable": true,
  "schemaVersion": 39,
  "tags": ["rag", "ask-my-docs"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "timezone": "browser",
  "title": "Ask My Docs · RAG Quality",
  "uid": "ask-my-docs-rag",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Citation-valid rate (5m)",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 5},
      "targets": [
        {
          "expr": "sum(rate(rag_requests_total{citation_valid=\"true\"}[5m])) / clamp_min(sum(rate(rag_requests_total[5m])), 1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "percentunit", "thresholds": {"mode": "absolute", "steps": [
          {"color": "red", "value": null},
          {"color": "orange", "value": 0.7},
          {"color": "green", "value": 0.9}
        ]}}
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Requests / min",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 5},
      "targets": [
        {"expr": "sum(rate(rag_requests_total[1m])) * 60", "refId": "A"}
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Cost USD (1h)",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 5},
      "targets": [
        {"expr": "sum(increase(llm_cost_usd_total[1h]))", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "currencyUSD"}}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Ingestion outcomes (1h)",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 5},
      "targets": [
        {"expr": "sum by (status) (increase(document_ingestions_total[1h]))", "refId": "A", "legendFormat": "{{status}}"}
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Latency p50 / p95 (per domain)",
      "gridPos": {"x": 0, "y": 5, "w": 12, "h": 9},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, domain) (rate(rag_request_latency_seconds_bucket[5m])))",
          "refId": "p50",
          "legendFormat": "p50 {{domain}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, domain) (rate(rag_request_latency_seconds_bucket[5m])))",
          "refId": "p95",
          "legendFormat": "p95 {{domain}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Token usage (prompt vs completion)",
      "gridPos": {"x": 12, "y": 5, "w": 12, "h": 9},
      "targets": [
        {
          "expr": "sum by (kind) (rate(llm_tokens_total[5m]))",
          "refId": "A",
          "legendFormat": "{{kind}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Retrieval candidates per stage",
      "gridPos": {"x": 0, "y": 14, "w": 12, "h": 9},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, stage) (rate(retrieval_candidates_bucket[5m])))",
          "refId": "A",
          "legendFormat": "p50 {{stage}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Citation-valid rate by domain",
      "gridPos": {"x": 12, "y": 14, "w": 12, "h": 9},
      "targets": [
        {
          "expr": "sum by (domain) (rate(rag_requests_total{citation_valid=\"true\"}[5m])) / clamp_min(sum by (domain) (rate(rag_requests_total[5m])), 1)",
          "refId": "A",
          "legendFormat": "{{domain}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit"}}
    }
  ]
}
